CENTAURUS_AGENT_UI_BIND_ADDRESS=127.0.0.1
CENTAURUS_AGENT_UI_PORT=8787
CENTAURUS_AGENT_UI_REMOTE_ACCESS_ENABLED=false
CENTAURUS_AGENT_CONFIG_PATH={{INSTALL_DIR}}/agent-data/config.yml
CENTAURUS_AGENT_LOG_PATH={{INSTALL_DIR}}/logs/centaurus-agent.log
CENTAURUS_AGENT_VERSION={{AGENT_VERSION}}
CENTAURUS_AGENT_AUTO_CONNECT=true
CENTAURUS_AGENT_RECONNECT_DELAY_SECONDS=10
CENTAURUS_AGENT_TRUSTED_CERTIFICATES_FILE=
JAVA_HOME={{INSTALL_DIR}}/runtime
JAVA_OPTS="-Xms128m -Xmx256m"
