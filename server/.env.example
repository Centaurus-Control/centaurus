CENTAURUS_SERVER_PORT=8080
CENTAURUS_DB_URL=jdbc:postgresql://localhost:5432/centaurus
CENTAURUS_DB_USERNAME=centaurus
CENTAURUS_DB_PASSWORD=change-me
CENTAURUS_JPA_DDL_AUTO=validate
CENTAURUS_FLYWAY_ENABLED=true
CENTAURUS_FLYWAY_BASELINE_ON_MIGRATE=true
CENTAURUS_FLYWAY_BASELINE_VERSION=1

CENTAURUS_AUTH_ACCESS_TOKEN_TTL=15m
CENTAURUS_AUTH_REFRESH_TOKEN_TTL=365d
CENTAURUS_AUTH_REFRESH_COOKIE_NAME=centaurus_refresh_token
CENTAURUS_AUTH_REFRESH_COOKIE_SECURE_MODE=AUTO
CENTAURUS_AUTH_JWT_SECRET=change-me-to-a-long-random-secret-with-at-least-32-bytes

CENTAURUS_BOOTSTRAP_ADMIN_USERNAME=admin
CENTAURUS_BOOTSTRAP_ADMIN_PASSWORD=change-me

CENTAURUS_ENROLLMENT_TOKEN_TTL=1h
CENTAURUS_ENROLLMENT_SERVER_URL=http://localhost:8080
CENTAURUS_ENROLLMENT_WS_URL=ws://localhost:8080/agent/ws
